rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate generic ID strings to prevent resource exhaustion attacks
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to validate RSVP document structure
    function isValidRSVP(data) {
      return data.keys().hasAll(['fullName', 'phoneOrEmail', 'attendingEvents', 'guestsCount', 'foodPreference', 'specialMessage', 'submittedAt'])
        && data.keys().size() == 7
        && data.fullName is string 
        && data.fullName.size() > 0 
        && data.fullName.size() <= 120
        && data.phoneOrEmail is string 
        && data.phoneOrEmail.size() <= 120
        && data.attendingEvents is list 
        && data.attendingEvents.size() > 0 
        && data.attendingEvents.size() <= 10
        && data.guestsCount is int 
        && data.guestsCount >= 1 
        && data.guestsCount <= 100
        && data.foodPreference is string 
        && (data.foodPreference == 'veg' || data.foodPreference == 'non-veg' || data.foodPreference == 'jain')
        && data.specialMessage is string 
        && data.specialMessage.size() <= 1000
        && data.submittedAt is string;
    }

    // Helper to validate Blessing document structure
    function isValidBlessing(data) {
      return data.keys().hasAll(['senderName', 'relation', 'message', 'cardStyle', 'submittedAt'])
        && data.keys().size() == 5
        && data.senderName is string 
        && data.senderName.size() > 0 
        && data.senderName.size() <= 120
        && data.relation is string 
        && data.relation.size() > 0 
        && data.relation.size() <= 100
        && data.message is string 
        && data.message.size() > 0 
        && data.message.size() <= 1500
        && data.cardStyle is int 
        && data.cardStyle >= 0 
        && data.cardStyle <= 10
        && data.submittedAt is string;
    }

    // 2. RSVP Rules
    match /rsvps/{rsvpId} {
      allow create: if isValidId(rsvpId) && isValidRSVP(request.resource.data);
      // Deny reading, updating, and deleting to prevent guest snooping, spamming, or data loss
      allow read, update, delete: if false;
    }

    // 3. Blessing Rules
    match /blessings/{blessingId} {
      // Allow everyone to read the guestbook blessings
      allow read: if true;
      // Allow everyone to post a blessing after validation
      allow create: if isValidId(blessingId) && isValidBlessing(request.resource.data);
      // Blessings are immutable and cannot be updated or deleted by guests
      allow update, delete: if false;
    }
  }
}
